# OneBot v11 WebSocket endpoint (required)
ONEBOT_WS_URL=ws://127.0.0.1:3001

# Optional access token for OneBot authentication
ONEBOT_ACCESS_TOKEN=

# Daily digest push time, HH:MM format
DAILY_TIME=20:00

# Timezone for the scheduler
TIMEZONE=Asia/Shanghai

# Maximum news items per digest
NEWS_MAX_ITEMS=8

# Path to SQLite database
STORAGE_PATH=./data/bot.sqlite

# Max alert messages per group per poll cycle (extras summarized)
ALERT_MAX_PER_GROUP=2

# Persona skill pack: neutral (default) or maid_cat
PERSONA=neutral
